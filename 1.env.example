# =====================================================
# Infor Bridge — Configuración
# =====================================================
# Copiá este archivo a `.env` (sin .example) y completá los valores.
# Guardalo como C:\infor-bridge\.env

# Puerto local de la API (no cambies a menos que sepas qué hacés)
PORT=8787

# Token de autenticación. GENERÁ UNO NUEVO con PowerShell:
#   [Convert]::ToBase64String((1..48 | ForEach-Object {Get-Random -Max 256}))
# Pegalo acá. ESTE MISMO TOKEN va en Railway como INFOR_API_KEY.
API_KEY=PEGA_AQUI_EL_TOKEN_GENERADO

# =====================================================
# Conexión a SQL Server 2008
# =====================================================
MSSQL_USER=sa
MSSQL_PASS=PEGA_AQUI_LA_CONTRASEÑA_DE_SA
MSSQL_HOST=localhost
MSSQL_PORT=1433

# Nombre EXACTO de la base de datos (mayúsculas/minúsculas como aparece en SSMS)
MSSQL_DB=Infor

# =====================================================
# Whitelist de tablas
# =====================================================
# Tablas que la API puede LEER (separadas por coma, SIN espacios después de la coma).
# Mayúsculas/minúsculas exactas como están en SQL Server.
# La API rechaza con 403 cualquier tabla que NO esté en esta lista.
ALLOWED_READ_TABLES=Productos,Inventario,Clientes,Facturas

# Tablas que la API puede MODIFICAR (UPDATE).
# Suele ser un subconjunto más chico de ALLOWED_READ_TABLES.
# Solo poné acá las tablas donde está bien que la web cambie datos.
ALLOWED_WRITE_TABLES=Productos,Inventario
