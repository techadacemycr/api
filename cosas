Restart-Service InforBridge
Start-Sleep -Seconds 5
Get-Service InforBridge
Write-Host "=== service-out.log ==="
Get-Content C:\infor-bridge\service-out.log -Tail 20
Write-Host "=== service-err.log ==="
Get-Content C:\infor-bridge\service-err.log -Tail 20

Get-Service cloudflared
Write-Host "=== últimas líneas del log de cloudflared ==="
Get-Content C:\cloudflared\cloudflared.log -Tail 30

& "C:\cloudflared\cloudflared.exe" tunnel list

Get-ChildItem -Path C:\ -Filter "cloudflared.exe" -Recurse -ErrorAction SilentlyContinue | Select-Object FullName

C:\nssm\win64\nssm.exe get cloudflared AppStdout
C:\nssm\win64\nssm.exe get cloudflared AppStderr
C:\nssm\win64\nssm.exe get cloudflared Application
C:\nssm\win64\nssm.exe get cloudflared AppParameters
