$f = 'C:\infor-bridge\server.js'
$bak = "$f.bak-" + (Get-Date -Format 'yyyyMMdd-HHmmss')
Copy-Item $f $bak
Write-Host "Backup: $bak" -ForegroundColor Cyan

$c = Get-Content $f -Raw
$changed = $false

if ($c -notmatch 'ALLOWED_READ\s*=\s*\[[^\]]*UserDefinedFields') {
  $c = $c -replace '(ALLOWED_READ\s*=\s*\[\s*)', "`$1'UserDefinedFields', "
  $changed = $true
  Write-Host "+ ALLOWED_READ  -> UserDefinedFields agregada" -ForegroundColor Green
} else {
  Write-Host "= ALLOWED_READ  -> ya existia" -ForegroundColor Yellow
}

if ($c -notmatch 'ALLOWED_WRITE\s*=\s*\[[^\]]*UserDefinedFields') {
  $c = $c -replace '(ALLOWED_WRITE\s*=\s*\[\s*)', "`$1'UserDefinedFields', "
  $changed = $true
  Write-Host "+ ALLOWED_WRITE -> UserDefinedFields agregada" -ForegroundColor Green
} else {
  Write-Host "= ALLOWED_WRITE -> ya existia" -ForegroundColor Yellow
}

if ($changed) {
  # PS 4.0 no tiene -NoNewline en Set-Content; usamos .NET para preservar
  # el archivo exactamente como Node lo necesita (UTF-8 sin BOM, sin LF extra).
  $utf8 = New-Object System.Text.UTF8Encoding $false
  [System.IO.File]::WriteAllText($f, $c, $utf8)

  Write-Host "Reiniciando InforBridge..." -ForegroundColor Yellow
  Restart-Service InforBridge
  Start-Sleep -Seconds 3

  $svc = Get-Service InforBridge
  if ($svc.Status -eq 'Running') {
    Write-Host ("OK - Servicio: " + $svc.Status) -ForegroundColor Green
  } else {
    Write-Host ("FALLO - Servicio: " + $svc.Status) -ForegroundColor Red
  }
  Get-Content C:\infor-bridge\service-out.log -Tail 10
} else {
  Write-Host "Sin cambios - no reinicio el servicio" -ForegroundColor Cyan
}




